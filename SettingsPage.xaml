<Page
    x:Class="MusicBox.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{x:Null}">

    <Page.Resources>
        <Style x:Key="SettingHeaderGridStyle" TargetType="Grid">
            <Setter Property="ColumnSpacing" Value="12"/>
        </Style>

        <Style x:Key="SettingCardBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="16,10,16,10"/>
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="SettingDescStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalScrollMode="Disabled">
            <Grid Padding="32,24">
                <StackPanel Spacing="12"
                            MaxWidth="1680"
                            HorizontalAlignment="Stretch">
                    <TextBlock x:Name="PageTitleText"
                               Text="Settings"
                               FontSize="24"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="PersonalizationTitleText"
                               Text="Personalization"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               FontSize="14"/>

                    <Expander x:Name="ThemeExpander"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Left"
                              IsExpanded="True"
                              ExpandDirection="Down"
                              Background="Transparent"
                              BorderThickness="0"
                              CornerRadius="5"
                              Padding="0"
                              ContentTransitions="{x:Null}">
                        <Expander.Header>
                            <Grid Style="{StaticResource SettingHeaderGridStyle}"
                                  Margin="0,10,0,10"
                                  HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <FontIcon FontFamily="Segoe MDL2 Assets"
                                          Glyph="&#xE790;"
                                          VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock x:Name="ThemeTitleText" Text="Theme"/>
                                    <TextBlock x:Name="ThemeDescText" Text="Choose app appearance theme" Style="{StaticResource SettingDescStyle}"/>
                                </StackPanel>

                                <TextBlock x:Name="ThemeSummaryText"
                                           Grid.Column="2"
                                           Text="Use system setting"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </Expander.Header>

                        <Expander.Content>
                            <StackPanel Spacing="8" Margin="48,10,0,10" HorizontalAlignment="Stretch">
                                <RadioButton x:Name="ThemeSystemRadio"
                                             GroupName="ThemeGroup"
                                             Content="Use system setting"
                                             HorizontalAlignment="Left"
                                             Checked="ThemeRadio_Checked"/>

                                <RadioButton x:Name="ThemeLightRadio"
                                             GroupName="ThemeGroup"
                                             Content="Light"
                                             HorizontalAlignment="Left"
                                             Checked="ThemeRadio_Checked"/>

                                <RadioButton x:Name="ThemeDarkRadio"
                                             GroupName="ThemeGroup"
                                             Content="Dark"
                                             HorizontalAlignment="Left"
                                             Checked="ThemeRadio_Checked"/>
                            </StackPanel>
                        </Expander.Content>
                    </Expander>

                    <Border Style="{StaticResource SettingCardBorderStyle}" CornerRadius="5">
                        <Grid Style="{StaticResource SettingHeaderGridStyle}" HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                      Glyph="&#xE774;"
                                      VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock x:Name="LanguageTitleText" Text="Language"/>
                                <TextBlock x:Name="LanguageDescText" Text="Change display language" Style="{StaticResource SettingDescStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="4" Margin="0,0,10,0">
                                <ComboBox x:Name="LanguageComboBox"
                                          MinWidth="140"
                                          HorizontalAlignment="Right"
                                          SelectionChanged="LanguageComboBox_SelectionChanged">
                                    <ComboBoxItem Tag="system" Content="Use system setting"/>
                                    <ComboBoxItem Tag="zh-Hans" Content="Chinese (Simplified)"/>
                                    <ComboBoxItem Tag="en-US" Content="English"/>
                                </ComboBox>
                                <TextBlock x:Name="LanguageStatusText"
                                           Visibility="Collapsed"
                                           Style="{StaticResource SettingDescStyle}"
                                           Text=""/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock x:Name="FeaturesSectionTitleText"
                               Text="Software Features"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               FontSize="14"
                               Margin="0,10,0,0"/>

                    <Border Style="{StaticResource SettingCardBorderStyle}" CornerRadius="5">
                        <Grid Style="{StaticResource SettingHeaderGridStyle}" HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                      Glyph="&#xE8A3;"
                                      VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock x:Name="PlaybackAutoScrollTitleText" Text="Auto Scroll During Staff Playback"/>
                                <TextBlock x:Name="PlaybackAutoScrollDescText"
                                           Text="Keep the staff view following the playback cursor automatically"
                                           Style="{StaticResource SettingDescStyle}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <ToggleSwitch x:Name="PlaybackAutoScrollToggleSwitch"
                                          Grid.Column="2"
                                          Header=""
                                          Margin="0,0,-40,0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Toggled="PlaybackAutoScrollToggleSwitch_Toggled"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingCardBorderStyle}" CornerRadius="5">
                        <Grid Style="{StaticResource SettingHeaderGridStyle}" HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                      Glyph="&#xE7FC;"
                                      VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock x:Name="LabsTitleText" Text="Experimental Features"/>
                                <TextBlock x:Name="LabsDescText"
                                           Text="Show unfinished features such as the Recognize page"
                                           Style="{StaticResource SettingDescStyle}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <ToggleSwitch x:Name="ExperimentalFeaturesToggleSwitch"
                                          Grid.Column="2"
                                          Header=""
                                          Margin="0,0,-40,0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Toggled="ExperimentalFeaturesToggleSwitch_Toggled"/>
                        </Grid>
                    </Border>

                    <TextBlock x:Name="AboutSectionTitleText"
                               Text="About"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               FontSize="14"
                               Margin="0,10,0,0"/>

                    <Border Style="{StaticResource SettingCardBorderStyle}" CornerRadius="5">
                        <Grid Style="{StaticResource SettingHeaderGridStyle}" HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                      Glyph="&#xE895;"
                                      VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock x:Name="UpdateTitleText" Text="Software Update"/>
                                <TextBlock x:Name="UpdateStatusText"
                                           Text="Click the button to check for updates"
                                           Style="{StaticResource SettingDescStyle}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Button x:Name="CheckUpdateButton"
                                    Grid.Column="2"
                                    Content="Check for updates"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Click="CheckUpdateButton_Click"/>
                        </Grid>
                    </Border>

                    <Expander x:Name="AboutExpander"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Left"
                              IsExpanded="True"
                              ExpandDirection="Down"
                              Background="Transparent"
                              BorderThickness="0"
                              CornerRadius="5"
                              Padding="0"
                              ContentTransitions="{x:Null}">
                        <Expander.Header>
                            <Grid Style="{StaticResource SettingHeaderGridStyle}"
                                  Margin="0,15,0,15"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <FontIcon FontFamily="Segoe MDL2 Assets"
                                          Glyph="&#xE946;"
                                          VerticalAlignment="Center"/>

                                <TextBlock x:Name="AboutHeaderText"
                                           Grid.Column="1"
                                           Text="MusicBox"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Expander.Header>

                        <Expander.Content>
                            <Grid Margin="48,10,0,10" RowSpacing="10" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="AboutVersionLabelText"
                                           Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Version"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock x:Name="AboutVersionValueText"
                                           Grid.Row="0"
                                           Grid.Column="1"
                                           Text="--"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <TextBlock x:Name="AboutBuildLabelText"
                                           Grid.Row="1"
                                           Grid.Column="0"
                                           Text="Build Number"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock x:Name="AboutBuildValueText"
                                           Grid.Row="1"
                                           Grid.Column="1"
                                           Text="--"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <TextBlock x:Name="AboutAuthorLabelText"
                                           Grid.Row="2"
                                           Grid.Column="0"
                                           Text="Author"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock x:Name="AboutAuthorValueText"
                                           Grid.Row="2"
                                           Grid.Column="1"
                                           Text="Rylan"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </Expander.Content>
                    </Expander>

                    <StackPanel Spacing="4" Margin="0,6,0,0" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6"
                                    HorizontalAlignment="Center">
                            <FontIcon x:Name="WarningIcon"
                                      FontFamily="Segoe MDL2 Assets"
                                      Glyph="&#xE7BA;"
                                      VerticalAlignment="Center"/>
                            <TextBlock x:Name="WarningTitleText"
                                       Text="Work in Progress"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="WarningBodyText"
                                   Text="This project is currently under active development and some features may be incomplete or unstable."
                                   Style="{StaticResource SettingDescStyle}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="WrapWholeWords"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>



