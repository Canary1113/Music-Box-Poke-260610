<Page
    x:Class="MusicBox.ComposeWorkbenchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{x:Null}">

    <ScrollViewer x:Name="RootScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  VerticalScrollMode="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled">
        <Grid Width="{Binding ActualWidth, ElementName=RootScrollViewer}"
              MaxWidth="1500"
              HorizontalAlignment="Stretch"
              Padding="48,32,48,36"
              RowSpacing="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="8">
                <TextBlock x:Name="PageTitleText"
                           Text="智能创作"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                <TextBlock x:Name="PageSubtitleText"
                           Text="根据标题、情绪与长度生成多个旋律方案，并快速试听与写入五线谱。"
                           FontSize="14"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <Border Grid.Row="1"
                    CornerRadius="10"
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid ColumnSpacing="24"
                      RowSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TitleLabelText"
                               Grid.Column="0"
                               Text="标题"
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock x:Name="MoodLabelText"
                               Grid.Column="1"
                               Text="情绪"
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock x:Name="LengthLabelText"
                               Grid.Column="2"
                               Text="长度"
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                    <TextBox x:Name="TitleBox"
                             Grid.Row="1"
                             Grid.Column="0"
                             Text="智能创作"
                             Height="40"/>

                    <ComboBox x:Name="MoodBox"
                              Grid.Row="1"
                              Grid.Column="1"
                              Height="40"
                              HorizontalAlignment="Stretch">
                        <ComboBoxItem x:Name="MoodCalmItem" Tag="calm">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE76E;" FontSize="16"/>
                                <TextBlock Text="平静"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem x:Name="MoodPositiveItem" Tag="positive">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE9D2;" FontSize="16"/>
                                <TextBlock Text="积极"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem x:Name="MoodSadItem" Tag="sad">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE7BA;" FontSize="16"/>
                                <TextBlock Text="忧伤"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem x:Name="MoodSleepItem" Tag="sleep">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE823;" FontSize="16"/>
                                <TextBlock Text="睡眠"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem x:Name="MoodHopefulItem" Tag="hopeful">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEB51;" FontSize="16"/>
                                <TextBlock Text="希望"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem x:Name="MoodNostalgicItem" Tag="nostalgic">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE787;" FontSize="16"/>
                                <TextBlock Text="怀旧"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem x:Name="MoodDreamyItem" Tag="dreamy">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEB9F;" FontSize="16"/>
                                <TextBlock Text="梦幻"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem x:Name="MoodTenseItem" Tag="tense">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE814;" FontSize="16"/>
                                <TextBlock Text="紧张"/>
                            </StackPanel>
                        </ComboBoxItem>
                    </ComboBox>

                    <ComboBox x:Name="LengthBox"
                              Grid.Row="1"
                              Grid.Column="2"
                              Height="40"
                              HorizontalAlignment="Stretch">
                        <ComboBoxItem x:Name="LengthShortItem" Tag="short">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE916;" FontSize="16"/>
                                <TextBlock Text="短"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem x:Name="LengthMediumItem" Tag="medium">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE121;" FontSize="16"/>
                                <TextBlock Text="中"/>
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem x:Name="LengthLongItem" Tag="long">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE7C1;" FontSize="16"/>
                                <TextBlock Text="长"/>
                            </StackPanel>
                        </ComboBoxItem>
                    </ComboBox>

                    <Button x:Name="GenerateButton"
                            Grid.Row="1"
                            Grid.Column="3"
                            Height="40"
                            MinWidth="120"
                            Style="{ThemeResource AccentButtonStyle}"
                            Click="GenerateButton_Click"/>

                    <Button x:Name="RetryButton"
                            Grid.Row="1"
                            Grid.Column="4"
                            Height="40"
                            MinWidth="110"
                            Click="RetryButton_Click"/>

                    <Border Grid.Row="1"
                            Grid.Column="5"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            CornerRadius="8"
                            Padding="12,8"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE73E;"
                                      FontSize="14"
                                      Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                            <TextBlock x:Name="GeneratedBadgeText"
                                       Text="已生成 3 个候选方案"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="StatusText"
                               Grid.Row="2"
                               Grid.ColumnSpan="6"
                               Visibility="Collapsed"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="2"
                  ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        CornerRadius="12"
                        Padding="20"
                        MinHeight="480"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="42"
                                    Height="42"
                                    CornerRadius="21"
                                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}">
                                <FontIcon Glyph="&#xEC4F;"
                                          FontSize="20"
                                          Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                            </Border>
                            <TextBlock x:Name="Option1TitleText"
                                       Grid.Column="1"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                            <Button x:Name="Option1KeepButton"
                                    Grid.Column="2"
                                    Width="40"
                                    Height="40"
                                    Padding="0"
                                    Tag="0"
                                    HorizontalAlignment="Right"
                                    Click="ToggleKeepButton_Click"/>
                        </Grid>

                        <Grid Grid.Row="1" ColumnSpacing="8" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8D4;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="调号" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="Option1KeyText" Text="-" FontSize="13"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8FD;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="拍号" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="Option1MeterText" Text="-" FontSize="13"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xECA5;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="小节数" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="Option1MeasuresText" Text="-" FontSize="13"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xEC4F;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="速度" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="Option1TempoText" Text="-" FontSize="13"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE121;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="总时长" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="Option1DurationText" Text="-" FontSize="13"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="2" CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE9D2;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="偏好预测" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="Option1PreferenceText" Text="-" FontSize="13"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock x:Name="Option1SummaryText"
                                   Grid.Row="2"
                                   FontSize="14"
                                   LineHeight="22"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <Border Grid.Row="3"
                                Height="1"
                                Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                        <Grid Grid.Row="4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="分类评分" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <ProgressBar x:Name="Option1ScoreProgress"
                                         Grid.Column="1"
                                         Maximum="100"
                                         Value="50"
                                         Height="6"
                                         VerticalAlignment="Center"/>
                            <TextBlock x:Name="Option1RatingValueText"
                                       Grid.Column="2"
                                       Width="32"
                                       Text="50"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="Option1RatingSlider"
                                    Visibility="Collapsed"
                                    Tag="0"
                                    Minimum="0"
                                    Maximum="100"
                                    SmallChange="5"
                                    LargeChange="10"
                                    StepFrequency="5"
                                    TickFrequency="10"
                                    IsEnabled="False"
                                    ValueChanged="RatingSlider_ValueChanged"/>
                            <Button x:Name="Option1RateButton"
                                    Visibility="Collapsed"
                                    Tag="0"
                                    IsEnabled="False"
                                    Click="SaveRatingButton_Click"/>
                        </Grid>

                        <Grid Grid.Row="5" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="Option1PlayButton"
                                    Tag="0"
                                    Height="40"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    Click="PlayCandidateButton_Click"/>
                            <Button x:Name="Option1ExportAudioButton"
                                    Grid.Column="1"
                                    Tag="0"
                                    Width="48"
                                    Height="40"
                                    MinWidth="48"
                                    Padding="0"
                                    Click="SaveCandidateAudioButton_Click"/>
                            <Button x:Name="Option1ApplyButton"
                                    Grid.Column="2"
                                    Tag="0"
                                    Height="40"
                                    MinWidth="170"
                                    IsEnabled="False"
                                    Click="ApplyCandidateButton_Click"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        CornerRadius="12"
                        Padding="20"
                        MinHeight="480"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="42" Height="42" CornerRadius="21" Background="{ThemeResource SystemFillColorCautionBackgroundBrush}">
                                <FontIcon Glyph="&#xEC4F;" FontSize="20" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                            </Border>
                            <TextBlock x:Name="Option2TitleText" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold"/>
                            <Button x:Name="Option2KeepButton" Grid.Column="2" Width="40" Height="40" Padding="0" Tag="1" HorizontalAlignment="Right" Click="ToggleKeepButton_Click"/>
                        </Grid>
                        <Grid Grid.Row="1" ColumnSpacing="8" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE8D4;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock Text="调号" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock x:Name="Option2KeyText" Text="-" FontSize="13"/></StackPanel></Border>
                            <Border Grid.Column="1" CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE8FD;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock Text="拍号" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock x:Name="Option2MeterText" Text="-" FontSize="13"/></StackPanel></Border>
                            <Border Grid.Column="2" CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xECA5;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock Text="小节数" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock x:Name="Option2MeasuresText" Text="-" FontSize="13"/></StackPanel></Border>
                            <Border Grid.Row="1" CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xEC4F;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock Text="速度" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock x:Name="Option2TempoText" Text="-" FontSize="13"/></StackPanel></Border>
                            <Border Grid.Row="1" Grid.Column="1" CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE121;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock Text="总时长" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock x:Name="Option2DurationText" Text="-" FontSize="13"/></StackPanel></Border>
                            <Border Grid.Row="1" Grid.Column="2" CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE9D2;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock Text="偏好预测" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock x:Name="Option2PreferenceText" Text="-" FontSize="13"/></StackPanel></Border>
                        </Grid>
                        <TextBlock x:Name="Option2SummaryText" Grid.Row="2" FontSize="14" LineHeight="22" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Border Grid.Row="3" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                        <Grid Grid.Row="4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="分类评分" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <ProgressBar x:Name="Option2ScoreProgress" Grid.Column="1" Maximum="100" Value="50" Height="6" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Option2RatingValueText" Grid.Column="2" Width="32" Text="50" TextAlignment="Right" VerticalAlignment="Center"/>
                            <Slider x:Name="Option2RatingSlider" Visibility="Collapsed" Tag="1" Minimum="0" Maximum="100" SmallChange="5" LargeChange="10" StepFrequency="5" TickFrequency="10" IsEnabled="False" ValueChanged="RatingSlider_ValueChanged"/>
                            <Button x:Name="Option2RateButton" Visibility="Collapsed" Tag="1" IsEnabled="False" Click="SaveRatingButton_Click"/>
                        </Grid>
                        <Grid Grid.Row="5" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="Option2PlayButton" Tag="1" Height="40" Style="{ThemeResource AccentButtonStyle}" Click="PlayCandidateButton_Click"/>
                            <Button x:Name="Option2ExportAudioButton" Grid.Column="1" Tag="1" Width="48" Height="40" MinWidth="48" Padding="0" Click="SaveCandidateAudioButton_Click"/>
                            <Button x:Name="Option2ApplyButton" Grid.Column="2" Tag="1" Height="40" MinWidth="170" IsEnabled="False" Click="ApplyCandidateButton_Click"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        CornerRadius="12"
                        Padding="20"
                        MinHeight="480"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="42" Height="42" CornerRadius="21" Background="{ThemeResource SystemFillColorCautionBackgroundBrush}">
                                <FontIcon Glyph="&#xEC4F;" FontSize="20" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                            </Border>
                            <TextBlock x:Name="Option3TitleText" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold"/>
                            <Button x:Name="Option3KeepButton" Grid.Column="2" Width="40" Height="40" Padding="0" Tag="2" HorizontalAlignment="Right" Click="ToggleKeepButton_Click"/>
                        </Grid>
                        <Grid Grid.Row="1" ColumnSpacing="8" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE8D4;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock Text="调号" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock x:Name="Option3KeyText" Text="-" FontSize="13"/></StackPanel></Border>
                            <Border Grid.Column="1" CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE8FD;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock Text="拍号" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock x:Name="Option3MeterText" Text="-" FontSize="13"/></StackPanel></Border>
                            <Border Grid.Column="2" CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xECA5;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock Text="小节数" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock x:Name="Option3MeasuresText" Text="-" FontSize="13"/></StackPanel></Border>
                            <Border Grid.Row="1" CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xEC4F;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock Text="速度" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock x:Name="Option3TempoText" Text="-" FontSize="13"/></StackPanel></Border>
                            <Border Grid.Row="1" Grid.Column="1" CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE121;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock Text="总时长" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock x:Name="Option3DurationText" Text="-" FontSize="13"/></StackPanel></Border>
                            <Border Grid.Row="1" Grid.Column="2" CornerRadius="6" Padding="10,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE9D2;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock Text="偏好预测" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><TextBlock x:Name="Option3PreferenceText" Text="-" FontSize="13"/></StackPanel></Border>
                        </Grid>
                        <TextBlock x:Name="Option3SummaryText" Grid.Row="2" FontSize="14" LineHeight="22" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Border Grid.Row="3" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                        <Grid Grid.Row="4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="分类评分" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <ProgressBar x:Name="Option3ScoreProgress" Grid.Column="1" Maximum="100" Value="50" Height="6" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Option3RatingValueText" Grid.Column="2" Width="32" Text="50" TextAlignment="Right" VerticalAlignment="Center"/>
                            <Slider x:Name="Option3RatingSlider" Visibility="Collapsed" Tag="2" Minimum="0" Maximum="100" SmallChange="5" LargeChange="10" StepFrequency="5" TickFrequency="10" IsEnabled="False" ValueChanged="RatingSlider_ValueChanged"/>
                            <Button x:Name="Option3RateButton" Visibility="Collapsed" Tag="2" IsEnabled="False" Click="SaveRatingButton_Click"/>
                        </Grid>
                        <Grid Grid.Row="5" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="Option3PlayButton" Tag="2" Height="40" Style="{ThemeResource AccentButtonStyle}" Click="PlayCandidateButton_Click"/>
                            <Button x:Name="Option3ExportAudioButton" Grid.Column="1" Tag="2" Width="48" Height="40" MinWidth="48" Padding="0" Click="SaveCandidateAudioButton_Click"/>
                            <Button x:Name="Option3ApplyButton" Grid.Column="2" Tag="2" Height="40" MinWidth="170" IsEnabled="False" Click="ApplyCandidateButton_Click"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
