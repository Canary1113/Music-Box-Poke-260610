<Page
    x:Class="MusicBox.EditorPage"
    Background="{x:Null}"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary x:Key="Default">
                <AcrylicBrush x:Key="PlaybackOverlayAcrylicBrush"
                              Opacity="1"
                              TintOpacity="0.05"
                              TintLuminosityOpacity="0.05"
                              AlwaysUseFallback="False"
                              TintColor="#FFFFFFFF"
                              FallbackColor="#80FFFFFF"/>
                <SolidColorBrush x:Key="ToolbarMicaSoftOverlayBrush" Color="#B3FFFFFF"/>
            </ResourceDictionary>
            <ResourceDictionary x:Key="Dark">
                <AcrylicBrush x:Key="PlaybackOverlayAcrylicBrush"
                              Opacity="1.00"
                              TintOpacity="0.05"
                              TintLuminosityOpacity="0.05"
                              AlwaysUseFallback="False"
                              TintColor="#FF000000"
                              FallbackColor="#80000000"/>
                <SolidColorBrush x:Key="ToolbarMicaSoftOverlayBrush" Color="#80000000"/>
            </ResourceDictionary>
        </ResourceDictionary.ThemeDictionaries>
        <ThemeShadow x:Key="ToolbarShadow"/>
        <SolidColorBrush x:Key="PlaybackGlassBrush" Color="#18FFFFFF"/>
        <LinearGradientBrush x:Key="PlaybackGlassEdgeBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#45FFFFFF" Offset="0"/>
            <GradientStop Color="#12FFFFFF" Offset="0.58"/>
            <GradientStop Color="#10DCEEFF" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PlaybackGlassSheenBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#46FFFFFF" Offset="0"/>
            <GradientStop Color="#0CFFFFFF" Offset="0.62"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
        </LinearGradientBrush>
        <Style x:Key="SegmentedRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Padding" Value="9,2"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <Grid>
                                <TextBlock x:Name="Label"
                                           Text="{TemplateBinding Content}"
                                           Margin="{TemplateBinding Padding}"
                                           Foreground="{TemplateBinding Foreground}"
                                           HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                           VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SystemControlBackgroundBaseLowBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SystemControlBackgroundBaseLowBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Unchecked">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Label" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Label" Storyboard.TargetProperty="FontWeight">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Normal"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Label" Storyboard.TargetProperty="TextDecorations">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="None"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                <VisualState x:Name="Checked">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Transparent"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SystemControlHighlightAccentBrush}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Label" Storyboard.TargetProperty="Foreground">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SystemControlHighlightAccentBrush}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Label" Storyboard.TargetProperty="FontWeight">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Normal"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Label" Storyboard.TargetProperty="TextDecorations">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="Underline"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                    <VisualState x:Name="Indeterminate"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NoteStepArrowButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="#CCFFFFFF"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#22000000"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="NoteStepDeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource NoteStepArrowButtonStyle}">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Background" Value="#CCFDECEC"/>
            <Setter Property="Foreground" Value="#C62828"/>
            <Setter Property="BorderBrush" Value="#40C62828"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ToolbarIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style x:Key="ToolbarIconOnlyButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="Root" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver"/>
                                    <VisualState x:Name="Pressed"/>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.42"
                                                             Duration="0:0:0"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolbarFlatDropDownButtonStyle" TargetType="DropDownButton">
            <Setter Property="Height" Value="19"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style x:Key="ToolbarFlatTextButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="19"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style x:Key="FloatingOverlayPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#E6FFFFFF"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="13"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Shadow" Value="{StaticResource ToolbarShadow}"/>
        </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid x:Name="RootGrid"
          Background="{x:Null}"
          KeyboardAcceleratorPlacementMode="Hidden"
          SizeChanged="RootGrid_SizeChanged"
          PointerPressed="RootGrid_PointerPressed">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <MenuBar x:Name="EditorMenuBar"
                 Grid.Row="0"
                 Margin="12,4,12,2"
                 Visibility="Collapsed"
                 IsHitTestVisible="False">
            <MenuBarItem x:Name="FileMenu" Title="文件" Visibility="Collapsed">
                <MenuFlyoutItem x:Name="FileNewMenuItem" Text="新建" Click="NewMenuItem_Click"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem x:Name="FileImportMusicXmlMenuItem" Text="导入 MusicXML" Click="ImportMusicXmlMenuItem_Click"/>
                <MenuFlyoutItem x:Name="FileExportMusicXmlMenuItem" Text="导出 MusicXML" Click="ExportMusicXmlMenuItem_Click"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem x:Name="FileExportAudioMenuItem" Text="导出 WAV" Click="ExportAudioMenuItem_Click"/>
                <MenuFlyoutItem x:Name="FileExportPdfMenuItem" Text="导出 PDF" Click="ExportPdfMenuItem_Click"/>
                <MenuFlyoutItem x:Name="FilePrintMenuItem" Text="打印..." Click="PrintMenuItem_Click"/>
            </MenuBarItem><MenuBarItem x:Name="TimeSignatureMenu" Title="拍号" Visibility="Collapsed">
                <RadioMenuFlyoutItem Text="2/4" Tag="2/4" GroupName="TimeSignature" Click="TimeSignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="3/4" Tag="3/4" GroupName="TimeSignature" Click="TimeSignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="4/4" Tag="4/4" GroupName="TimeSignature" Click="TimeSignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="6/8" Tag="6/8" GroupName="TimeSignature" Click="TimeSignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="9/8" Tag="9/8" GroupName="TimeSignature" Click="TimeSignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="12/8" Tag="12/8" GroupName="TimeSignature" Click="TimeSignatureMenuItem_Click"/>
            </MenuBarItem>
            <MenuBarItem x:Name="KeySignatureMenu" Title="调号" Visibility="Collapsed">
                <RadioMenuFlyoutItem Text="C 大调 / a 小调" Tag="0" GroupName="KeySignature" Click="KeySignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="G 大调 / e 小调" Tag="1" GroupName="KeySignature" Click="KeySignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="D 大调 / b 小调" Tag="2" GroupName="KeySignature" Click="KeySignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="A 大调 / 升f 小调" Tag="3" GroupName="KeySignature" Click="KeySignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="E 大调 / 升c 小调" Tag="4" GroupName="KeySignature" Click="KeySignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="B 大调 / 升g 小调" Tag="5" GroupName="KeySignature" Click="KeySignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="升F 大调 / 升d 小调" Tag="6" GroupName="KeySignature" Click="KeySignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="升C 大调 / 升a 小调" Tag="7" GroupName="KeySignature" Click="KeySignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="F 大调 / d 小调" Tag="-1" GroupName="KeySignature" Click="KeySignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="降B 大调 / g 小调" Tag="-2" GroupName="KeySignature" Click="KeySignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="降E 大调 / c 小调" Tag="-3" GroupName="KeySignature" Click="KeySignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="降A 大调 / f 小调" Tag="-4" GroupName="KeySignature" Click="KeySignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="降D 大调 / 降b 小调" Tag="-5" GroupName="KeySignature" Click="KeySignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="降G 大调 / 降e 小调" Tag="-6" GroupName="KeySignature" Click="KeySignatureMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="降C 大调 / 降a 小调" Tag="-7" GroupName="KeySignature" Click="KeySignatureMenuItem_Click"/>
            </MenuBarItem>
            <MenuBarItem x:Name="TempoMenu" Title="速度" Visibility="Collapsed">
                <RadioMenuFlyoutItem Text="Larghissimo 极缓板" KeyboardAcceleratorTextOverride="24" Tag="24" GroupName="Tempo" Click="TempoMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Grave 沉板" KeyboardAcceleratorTextOverride="35" Tag="35" GroupName="Tempo" Click="TempoMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Largo 广板" KeyboardAcceleratorTextOverride="50" Tag="50" GroupName="Tempo" Click="TempoMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Adagio 柔版" KeyboardAcceleratorTextOverride="56" Tag="56" GroupName="Tempo" Click="TempoMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Lento 慢板" KeyboardAcceleratorTextOverride="60" Tag="60" GroupName="Tempo" Click="TempoMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Larghetto 小广板" KeyboardAcceleratorTextOverride="63" Tag="63" GroupName="Tempo" Click="TempoMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Adagietto 小柔板" KeyboardAcceleratorTextOverride="66" Tag="66" GroupName="Tempo" Click="TempoMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Andante 行板" KeyboardAcceleratorTextOverride="76" Tag="76" GroupName="Tempo" Click="TempoMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Andantino 小行板" KeyboardAcceleratorTextOverride="84" Tag="84" GroupName="Tempo" Click="TempoMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Maestoso 庄板" KeyboardAcceleratorTextOverride="88" Tag="88" GroupName="Tempo" Click="TempoMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Moderato 中板" KeyboardAcceleratorTextOverride="96" Tag="96" GroupName="Tempo" Click="TempoMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Allegretto 小快板" KeyboardAcceleratorTextOverride="112" Tag="112" GroupName="Tempo" Click="TempoMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Allegro 快板" KeyboardAcceleratorTextOverride="120" Tag="120" GroupName="Tempo" Click="TempoMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Allegro vivace 快速板" KeyboardAcceleratorTextOverride="132" Tag="132" GroupName="Tempo" Click="TempoMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Vivace 活板" KeyboardAcceleratorTextOverride="144" Tag="144" GroupName="Tempo" Click="TempoMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Presto 急板" KeyboardAcceleratorTextOverride="168" Tag="168" GroupName="Tempo" Click="TempoMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Prestissimo 最急板" KeyboardAcceleratorTextOverride="200" Tag="200" GroupName="Tempo" Click="TempoMenuItem_Click"/>
            </MenuBarItem>
            <MenuBarItem x:Name="SnapMenu" Title="音符吸附">
                <RadioMenuFlyoutItem Text="四分音符" Tag="1" GroupName="SnapDivision" Click="SnapMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="八分音符" Tag="2" GroupName="SnapDivision" Click="SnapMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="十六分音符" Tag="4" GroupName="SnapDivision" Click="SnapMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="三十二分音符" Tag="8" GroupName="SnapDivision" Click="SnapMenuItem_Click"/>
            </MenuBarItem>
            <MenuBarItem x:Name="SymbolFontMenu" Title="显示" Visibility="Collapsed">
                <ToggleMenuFlyoutItem x:Name="ShowGridMenuItem" Text="网格" IsChecked="{Binding ShowBeatGrid, Mode=TwoWay}"/>
                <MenuFlyoutSubItem Text="每行小节数">
                    <ToggleMenuFlyoutItem x:Name="AutoAdjustMeasureRatioMenuItem"
                                          Text="自动调整比例"
                                          IsChecked="False"
                                          Click="AutoAdjustMeasureRatioMenuItem_Click"/>
                    <MenuFlyoutSeparator/>
                    <RadioMenuFlyoutItem Text="自动（默认）" Tag="auto" GroupName="MeasuresPerSystem" IsChecked="True" Click="MeasuresPerSystemMenuItem_Click"/>
                    <RadioMenuFlyoutItem Text="4" Tag="4" GroupName="MeasuresPerSystem" Click="MeasuresPerSystemMenuItem_Click"/>
                    <RadioMenuFlyoutItem Text="6" Tag="6" GroupName="MeasuresPerSystem" Click="MeasuresPerSystemMenuItem_Click"/>
                    <RadioMenuFlyoutItem Text="8" Tag="8" GroupName="MeasuresPerSystem" Click="MeasuresPerSystemMenuItem_Click"/>
                    <RadioMenuFlyoutItem Text="10" Tag="10" GroupName="MeasuresPerSystem" Click="MeasuresPerSystemMenuItem_Click"/>
                    <RadioMenuFlyoutItem Text="12" Tag="12" GroupName="MeasuresPerSystem" Click="MeasuresPerSystemMenuItem_Click"/>
                </MenuFlyoutSubItem>
                <MenuFlyoutSeparator/>
                <ToggleMenuFlyoutItem x:Name="AreaSelectMenuItem"
                                      Text="区域选择"
                                      Visibility="Collapsed"
                                      Click="AreaSelectMenuItem_Click"/>
                <MenuFlyoutItem x:Name="ClearAllMenuItem" Text="清空" Click="ClearAllMenuItem_Click"/>
                <MenuFlyoutSeparator/>
                <RadioMenuFlyoutItem Text="Bravura" Tag="Bravura.otf|Bravura" GroupName="SymbolFont" Click="MusicFontMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Leland" Tag="Leland.otf|Leland" GroupName="SymbolFont" Click="MusicFontMenuItem_Click"/>
                <RadioMenuFlyoutItem Text="Sebastian" Tag="Sebastian.otf|Sebastian" GroupName="SymbolFont" Click="MusicFontMenuItem_Click"/>
            </MenuBarItem>
        </MenuBar>

        <Grid x:Name="TopToolbarOverlay"
              Grid.Row="1"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Margin="0,8,0,0"
              Canvas.ZIndex="30">
            <Border CornerRadius="18"
                    Background="Transparent"
                    Translation="0,0,18"
                    Shadow="{StaticResource ToolbarShadow}">
                <Grid>
                    <SystemBackdropElement CornerRadius="18"
                                           IsHitTestVisible="False">
                        <SystemBackdropElement.SystemBackdrop>
                            <MicaBackdrop Kind="Base" />
                        </SystemBackdropElement.SystemBackdrop>
                    </SystemBackdropElement>
                    <Border Padding="2,0,2,0"
                            Background="{ThemeResource ToolbarMicaSoftOverlayBrush}"
                            CornerRadius="18">
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid x:Name="ToolbarShadowReceiver"/>
                        <Border x:Name="ToolbarCard"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="18"
                                Padding="2"
                                Translation="0,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <Button x:Name="UndoButton"
                                    Style="{StaticResource ToolbarIconOnlyButtonStyle}"
                                    ToolTipService.ToolTip="撤销 (Ctrl+Z)"
                                    Click="UndoButton_Click">
                                <FontIcon Glyph="&#xE7A7;" FontFamily="Segoe Fluent Icons" FontSize="13"/>
                            </Button>
                            <Button x:Name="RedoButton"
                                    Style="{StaticResource ToolbarIconOnlyButtonStyle}"
                                    ToolTipService.ToolTip="恢复 (Ctrl+Y)"
                                    Click="RedoButton_Click">
                                <FontIcon Glyph="&#xE7A6;" FontFamily="Segoe Fluent Icons" FontSize="13"/>
                            </Button>
                        </StackPanel>
                        <DropDownButton x:Name="ExpressionMarkButton" Content="表情记号" Style="{StaticResource ToolbarFlatDropDownButtonStyle}">
                            <DropDownButton.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="ppp" Tag="ppp" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="pp" Tag="pp" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="p" Tag="p" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="mp" Tag="mp" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="mf" Tag="mf" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="f" Tag="f" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="ff" Tag="ff" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="fff" Tag="fff" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="sf" Tag="sf" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="cresc." Tag="cresc_text" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="dim." Tag="dim_text" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="渐响符号" Tag="cresc" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="渐轻符号" Tag="dim" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="rit." Tag="rit" Click="ExpressionMarkMenuItem_Click"/>
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                        <DropDownButton x:Name="ScoreMarkButton" Content="谱面记号" Style="{StaticResource ToolbarFlatDropDownButtonStyle}">
                            <DropDownButton.Flyout>
                                <MenuFlyout Placement="Bottom">
                                    <MenuFlyoutItem Text="高音谱号" Tag="score_gclef" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="低音谱号" Tag="score_fclef" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="终止线" Tag="score_final_barline" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="反复记号" Tag="score_repeat_barline" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="回到标记" Tag="score_segno" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="八度记号" Tag="ottava" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="第一结尾" Tag="score_ending_1" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="第二结尾" Tag="score_ending_2" Click="ExpressionMarkMenuItem_Click"/>
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                        <DropDownButton x:Name="PedalMarkButton" Content="踏板" Style="{StaticResource ToolbarFlatDropDownButtonStyle}">
                            <DropDownButton.Flyout>
                                <MenuFlyout Placement="Bottom">
                                    <MenuFlyoutItem Text="踏板" Tag="ped" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="踏板抬起" Tag="ped_release" Click="ExpressionMarkMenuItem_Click"/>
                                    <MenuFlyoutItem Text="切分踏板线" Tag="ped_line" Click="ExpressionMarkMenuItem_Click"/>
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                        <Button x:Name="SlurToolButton" Content="连音" Style="{StaticResource ToolbarFlatTextButtonStyle}" Click="SlurToolButton_Click"/>
                        <Rectangle Width="1"
                                   Height="14"
                                   Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                                   Opacity="0.55"
                                   VerticalAlignment="Center"
                                   Margin="2,0,0,0"/>
                        <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Name="NoteLengthLabelText" Text="时值" VerticalAlignment="Center"/>
                            <ToggleSwitch x:Name="DurationModeToggleSwitch"
                                          MinWidth="50"
                                          VerticalAlignment="Center"
                                          OffContent=""
                                          OnContent=""
                                          Toggled="DurationModeToggleSwitch_Toggled"/>
                            <TextBlock x:Name="DurationModeStateText"
                                       Text="音符"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Margin="2,0,4,0"/>
                                <StackPanel x:Name="NoteLengthButtons" Orientation="Horizontal" Spacing="4">
                                    <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}"
                                                 Content="无"
                                                 Tag="None"
                                                 GroupName="NoteLength"
                                                 CornerRadius="8"
                                                 Checked="NoteLengthButton_Checked"/>
                                    <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}"
                                                 Content="全音符"
                                                 Tag="Whole"
                                                 GroupName="NoteLength"
                                                 CornerRadius="8"
                                                 Checked="NoteLengthButton_Checked"/>
                                    <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}"
                                                 Content="二分"
                                                 Tag="Half"
                                                 GroupName="NoteLength"
                                                 CornerRadius="8"
                                                 Checked="NoteLengthButton_Checked"/>
                                    <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}"
                                                  Content="四分"
                                                  Tag="Quarter"
                                                  GroupName="NoteLength"
                                                  CornerRadius="8"
                                                  Checked="NoteLengthButton_Checked"/>
                                    <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}"
                                                  Content="八分"
                                                  Tag="Eighth"
                                                  GroupName="NoteLength"
                                                  CornerRadius="8"
                                                  Checked="NoteLengthButton_Checked"/>
                                     <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}"
                                                   Content="十六分"
                                                   Tag="Sixteenth"
                                                   GroupName="NoteLength"
                                                   Padding="9,2"
                                                   CornerRadius="8"
                                                   Checked="NoteLengthButton_Checked"/>
                                      <RadioButton Style="{StaticResource SegmentedRadioButtonStyle}"
                                                   Content="三十二分"
                                                   Tag="ThirtySecond"
                                                   GroupName="NoteLength"
                                                   Padding="9,2"
                                                   CornerRadius="8"
                                                   Checked="NoteLengthButton_Checked"/>
                                      <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}" BorderThickness="0" Margin="3,0,0,0">
                                          <Button x:Name="NoteTypeButton"
                                                  Content="···"
                                                  MinWidth="38"
                                                  Padding="8,0"
                                                  Height="22"
                                                  CornerRadius="8"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  FontSize="16"
                                                  FontWeight="SemiBold"
                                                  HorizontalContentAlignment="Center"
                                                  VerticalContentAlignment="Center">
                                             <Button.Flyout>
                                                 <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                                    <ToggleMenuFlyoutItem x:Name="AccidentalSharpItem"
                                                                          Text="升号"
                                                                          Tag="Sharp"
                                                                          Click="AccidentalMenuItem_Click"/>
                                                    <ToggleMenuFlyoutItem x:Name="AccidentalDoubleSharpItem"
                                                                          Text="重升号"
                                                                          Tag="DoubleSharp"
                                                                          Click="AccidentalMenuItem_Click"/>
                                                    <ToggleMenuFlyoutItem x:Name="AccidentalFlatItem"
                                                                          Text="降号"
                                                                          Tag="Flat"
                                                                          Click="AccidentalMenuItem_Click"/>
                                                    <ToggleMenuFlyoutItem x:Name="AccidentalDoubleFlatItem"
                                                                          Text="重降号"
                                                                          Tag="DoubleFlat"
                                                                          Click="AccidentalMenuItem_Click"/>
                                                    <ToggleMenuFlyoutItem x:Name="AccidentalNaturalItem"
                                                                          Text="还原号"
                                                                          Tag="Natural"
                                                                           Click="AccidentalMenuItem_Click"/>
                                                     <MenuFlyoutSeparator/>
                                                     <ToggleMenuFlyoutItem x:Name="StaccatoMenuItem"
                                                                           Text="跳音"
                                                                           Click="NoteTypeToggleMenuItem_Click"/>
                                                     <ToggleMenuFlyoutItem x:Name="StaccatissimoMenuItem"
                                                                           Text="顿音"
                                                                           Click="NoteTypeToggleMenuItem_Click"/>
                                                     <ToggleMenuFlyoutItem x:Name="AccentMenuItem"
                                                                           Text="重音"
                                                                           Click="NoteTypeToggleMenuItem_Click"/>
                                                     <MenuFlyoutSeparator/>
                                                     <ToggleMenuFlyoutItem x:Name="AugmentationDotMenuItem"
                                                                           Text="附点"
                                                                           Click="NoteTypeToggleMenuItem_Click"/>
                                                     <MenuFlyoutSeparator/>
                                                     <MenuFlyoutSubItem x:Name="OrnamentSubMenuItem" Text="装饰音">
                                                         <RadioMenuFlyoutItem x:Name="OrnamentNoneMenuItem"
                                                                              Text="无"
                                                                              Tag="None"
                                                                              GroupName="NoteOrnament"
                                                                              IsChecked="True"
                                                                              Click="NoteOrnamentMenuItem_Click"/>
                                                         <RadioMenuFlyoutItem x:Name="OrnamentTrillMenuItem"
                                                                              Text="颤音"
                                                                              Tag="Trill"
                                                                              GroupName="NoteOrnament"
                                                                              Click="NoteOrnamentMenuItem_Click"/>
                                                         <RadioMenuFlyoutItem x:Name="OrnamentUpperMordentMenuItem"
                                                                              Text="上波音"
                                                                              Tag="UpperMordent"
                                                                              GroupName="NoteOrnament"
                                                                              Click="NoteOrnamentMenuItem_Click"/>
                                                         <RadioMenuFlyoutItem x:Name="OrnamentLowerMordentMenuItem"
                                                                              Text="下波音"
                                                                              Tag="LowerMordent"
                                                                              GroupName="NoteOrnament"
                                                                              Click="NoteOrnamentMenuItem_Click"/>
                                                         <RadioMenuFlyoutItem x:Name="OrnamentTurnMenuItem"
                                                                              Text="回音"
                                                                              Tag="Turn"
                                                                              GroupName="NoteOrnament"
                                                                              Click="NoteOrnamentMenuItem_Click"/>
                                                         <RadioMenuFlyoutItem x:Name="OrnamentInvertedTurnMenuItem"
                                                                              Text="逆回音"
                                                                              Tag="InvertedTurn"
                                                                              GroupName="NoteOrnament"
                                                                              Click="NoteOrnamentMenuItem_Click"/>
                                                         <RadioMenuFlyoutItem x:Name="OrnamentAppoggiaturaMenuItem"
                                                                              Text="倚音"
                                                                              Tag="Appoggiatura"
                                                                              GroupName="NoteOrnament"
                                                                              Click="NoteOrnamentMenuItem_Click"/>
                                                         <RadioMenuFlyoutItem x:Name="OrnamentAcciaccaturaMenuItem"
                                                                              Text="短倚音"
                                                                              Tag="Acciaccatura"
                                                                              GroupName="NoteOrnament"
                                                                              Click="NoteOrnamentMenuItem_Click"/>
                                                     </MenuFlyoutSubItem>
                                                 </MenuFlyout>
                                             </Button.Flyout>
                                          </Button>
                                      </Border>
                                  </StackPanel>
                          </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Visibility="Collapsed">
                            <Button x:Name="PlayMidiButton" Height="32" Width="36" Padding="0" ToolTipService.ToolTip="播放" Click="PlayMidiButton_Click" Foreground="LimeGreen">
                                <SymbolIcon Symbol="Play"/>
                            </Button>
                            <Button x:Name="PauseMidiButton" Height="32" Width="36" Padding="0" ToolTipService.ToolTip="暂停" Click="PauseMidiButton_Click" Foreground="DodgerBlue">
                                <SymbolIcon Symbol="Pause"/>
                            </Button>
                            <Button x:Name="StopMidiButton" Height="32" Width="36" Padding="0" ToolTipService.ToolTip="停止" Click="StopMidiButton_Click" Foreground="Tomato">
                                <SymbolIcon Symbol="Stop"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                        </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Margin="0"
                Padding="0"
                CornerRadius="5"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                Translation="0,0,16"
                VerticalAlignment="Stretch">
            <ScrollViewer x:Name="ScoreScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          SizeChanged="ScoreScrollViewer_SizeChanged"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          CornerRadius="8"
                          BorderThickness="0"
                          BorderBrush="Transparent"
                          Padding="0">
                <Grid Margin="-2,36,-2,-2" Background="Transparent">
                    <canvas:CanvasControl x:Name="StaffCanvas"
                                          Height="3600"
                                          VerticalAlignment="Top"
                                          ClearColor="Transparent"
                                          Draw="StaffCanvas_Draw"
                                          PointerPressed="StaffCanvas_PointerPressed"
                                          PointerMoved="StaffCanvas_PointerMoved"
                                          PointerReleased="StaffCanvas_PointerReleased" />
                    <Canvas x:Name="NoteStepOverlayCanvas">
                        <TextBox x:Name="TitleInlineEditor"
                                 Width="320"
                                 Height="44"
                                 Padding="10,8"
                                 Background="#E6FFFFFF"
                                 BorderBrush="Transparent"
                                 BorderThickness="0"
                                 Shadow="{StaticResource ToolbarShadow}"
                                 Translation="0,0,26"
                                 FontSize="22"
                                 FontWeight="Bold"
                                 TextAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Visibility="Collapsed"
                                 AcceptsReturn="False"
                                 KeyDown="TitleInlineEditor_KeyDown"
                                 LostFocus="TitleInlineEditor_LostFocus"/>
                        <Border x:Name="NoteStepPanel"
                                Visibility="Collapsed"
                                Translation="0,0,36"
                                Style="{StaticResource FloatingOverlayPanelStyle}">
                            <StackPanel Spacing="4">
                                <Button x:Name="NoteStepUpButton"
                                        Style="{StaticResource NoteStepArrowButtonStyle}"
                                        ToolTipService.ToolTip="音高上移一格"
                                        Click="NoteStepUpButton_Click">
                                    <TextBlock Text="▲" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="NoteStepDownButton"
                                        Style="{StaticResource NoteStepArrowButtonStyle}"
                                        ToolTipService.ToolTip="音高下移一格"
                                        Click="NoteStepDownButton_Click">
                                    <TextBlock Text="▼" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="NoteStepStemFlipButton"
                                        Style="{StaticResource NoteStepArrowButtonStyle}"
                                        ToolTipService.ToolTip="切换符干方向"
                                        Click="NoteStepStemFlipButton_Click">
                                    <TextBlock Text="⇵" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="NoteStepUnbeamButton"
                                        Style="{StaticResource NoteStepArrowButtonStyle}"
                                        Visibility="Collapsed"
                                        ToolTipService.ToolTip="解绑成组音符"
                                        Click="NoteStepUnbeamButton_Click">
                                    <FontIcon Glyph="&#xE71B;" FontFamily="Segoe Fluent Icons" FontSize="11"/>
                                </Button>
                                <Button x:Name="NoteStepMoreButton"
                                        Style="{StaticResource NoteStepArrowButtonStyle}"
                                        ToolTipService.ToolTip="更多音符设置"
                                        Click="NoteStepMoreButton_Click">
                                    <TextBlock Text="···" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="NoteStepDeleteButton"
                                        Style="{StaticResource NoteStepDeleteButtonStyle}"
                                        ToolTipService.ToolTip="删除选中音符"
                                        Click="NoteStepDeleteButton_Click">
                                    <FontIcon Glyph="&#xE74D;" FontSize="10" Foreground="#C62828"/>
                                </Button>
                            </StackPanel>
                        </Border>
                        <Border x:Name="ExpressionDeletePanel"
                                Visibility="Collapsed"
                                Translation="0,0,36"
                                Style="{StaticResource FloatingOverlayPanelStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button x:Name="ExpressionDeleteButton"
                                        Style="{StaticResource NoteStepDeleteButtonStyle}"
                                        ToolTipService.ToolTip="删除选中表情/连线"
                                        Click="ExpressionDeleteButton_Click">
                                    <FontIcon Glyph="&#xE74D;" FontSize="10" Foreground="#C62828"/>
                                </Button>
                            </StackPanel>
                        </Border>
                        <Border x:Name="OttavaEditPanel"
                                Visibility="Collapsed"
                                Translation="0,0,36"
                                Style="{StaticResource FloatingOverlayPanelStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button x:Name="OttavaDirectionButton"
                                        Style="{StaticResource NoteStepArrowButtonStyle}"
                                        ToolTipService.ToolTip="切换八度方向"
                                        Click="OttavaDirectionButton_Click">
                                    <TextBlock Text="⇵" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="OttavaDeleteButton"
                                        Style="{StaticResource NoteStepDeleteButtonStyle}"
                                        ToolTipService.ToolTip="删除八度记号"
                                        Click="OttavaDeleteButton_Click">
                                    <FontIcon Glyph="&#xE74D;" FontSize="10" Foreground="#C62828"/>
                                </Button>
                            </StackPanel>
                        </Border>
                        <Border x:Name="MeasureEditPanel"
                                Visibility="Collapsed"
                                Translation="0,0,36"
                                Style="{StaticResource FloatingOverlayPanelStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button x:Name="MeasureAddButton"
                                        Style="{StaticResource NoteStepArrowButtonStyle}"
                                        ToolTipService.ToolTip="在后面插入空白小节"
                                        Click="MeasureAddButton_Click">
                                    <TextBlock Text="+" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="MeasureDeleteButton"
                                        Style="{StaticResource NoteStepDeleteButtonStyle}"
                                        ToolTipService.ToolTip="删除当前小节"
                                        Click="MeasureDeleteButton_Click">
                                    <FontIcon Glyph="&#xE74D;" FontSize="10" Foreground="#C62828"/>
                                </Button>
                                <Button x:Name="MeasureDeleteSystemButton"
                                        Height="24"
                                        Padding="8,0"
                                        CornerRadius="12"
                                        Background="#CCFDECEC"
                                        BorderBrush="#40C62828"
                                        BorderThickness="1"
                                        ToolTipService.ToolTip="删除当前整行五线谱"
                                        Click="MeasureDeleteSystemButton_Click">
                                    <TextBlock Text="删整行" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#C62828"/>
                                </Button>
                                <Button x:Name="MeasureAddSystemButton"
                                        Height="24"
                                        Padding="8,0"
                                        CornerRadius="12"
                                        Background="#CCFFFFFF"
                                        BorderBrush="#2A000000"
                                        BorderThickness="1"
                                        ToolTipService.ToolTip="在末尾加一行五线谱"
                                        Click="MeasureAddSystemButton_Click">
                                    <TextBlock Text="加一行" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Border>
                        <Border x:Name="ClefEditPanel"
                                Visibility="Collapsed"
                                Translation="0,0,36"
                                Style="{StaticResource FloatingOverlayPanelStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button x:Name="ClefSetTrebleButton"
                                        Style="{StaticResource NoteStepArrowButtonStyle}"
                                        CornerRadius="12"
                                        Background="#CCFFFFFF"
                                        BorderBrush="#2A000000"
                                        BorderThickness="1"
                                        ToolTipService.ToolTip="切换为高音谱号"
                                        Click="ClefSetTrebleButton_Click">
                                    <TextBlock Text="&#x1D11E;" FontSize="14" FontFamily="Segoe UI Symbol" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="ClefSetBassButton"
                                        Style="{StaticResource NoteStepArrowButtonStyle}"
                                        CornerRadius="12"
                                        Background="#CCFFFFFF"
                                        BorderBrush="#2A000000"
                                        BorderThickness="1"
                                        ToolTipService.ToolTip="切换为低音谱号"
                                        Click="ClefSetBassButton_Click">
                                    <TextBlock Text="&#x1D122;" FontSize="14" FontFamily="Segoe UI Symbol" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Border>
                        <Border x:Name="RepeatEditPanel"
                                Visibility="Collapsed"
                                Translation="0,0,36"
                                Style="{StaticResource FloatingOverlayPanelStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button x:Name="RepeatDirectionButton"
                                        Style="{StaticResource NoteStepArrowButtonStyle}"
                                        ToolTipService.ToolTip="切换反复方向（小节末/小节初）"
                                        Click="RepeatDirectionButton_Click">
                                    <TextBlock Text="↦" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="RepeatDeleteButton"
                                        Style="{StaticResource NoteStepDeleteButtonStyle}"
                                        ToolTipService.ToolTip="删除反复记号"
                                        Click="RepeatDeleteButton_Click">
                                    <FontIcon Glyph="&#xE74D;" FontSize="10" Foreground="#C62828"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Canvas>
                </Grid>
            </ScrollViewer>
        </Border>

        <Grid Grid.RowSpan="2"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              IsHitTestVisible="True">
            <Border x:Name="PlaybackOverlay"
                    Visibility="Collapsed"
                    IsHitTestVisible="True"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,12"
                    Padding="10,5"
                    Background="{ThemeResource PlaybackOverlayAcrylicBrush}"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="24"
                    Translation="0,0,24"
                    RenderTransformOrigin="0.5,1"
                    Shadow="{StaticResource ToolbarShadow}"
                    PointerEntered="PlaybackOverlay_PointerEntered"
                    PointerExited="PlaybackOverlay_PointerExited">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="PlaybackOverlayScaleTransform" ScaleX="0.5" ScaleY="0.5"/>
                </Border.RenderTransform>
                <Grid ColumnSpacing="8" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="PlaybackOverlaySheen"
                            IsHitTestVisible="False"
                            Visibility="Collapsed"
                            Grid.ColumnSpan="5"
                            VerticalAlignment="Top"
                            Height="6"
                            Background="{StaticResource PlaybackGlassSheenBrush}"
                            CornerRadius="0"
                            Opacity="0.30"
                            Margin="2,-1,-2,0"/>
                    <Border x:Name="PlaybackOverlayRefraction"
                            IsHitTestVisible="False"
                            Grid.ColumnSpan="5"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="#00FFFFFF"
                            CornerRadius="24"
                            Opacity="1.00"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Margin="0"/>
                    <TextBlock x:Name="PlaybackProgressText"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Margin="4,0,3,0"
                               RenderTransformOrigin="0.5,0.5"
                               FontSize="12"
                               Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                               Text="00:00 / 00:00">
                        <TextBlock.RenderTransform>
                            <ScaleTransform x:Name="PlaybackProgressTextInverseScaleTransform"
                                            ScaleX="1"
                                            ScaleY="1"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <Slider x:Name="PlaybackProgressSlider"
                            Grid.Column="1"
                            Height="32"
                            Margin="4,2,4,2"
                            Padding="8,0,8,0"
                            Minimum="0"
                            Maximum="1"
                            Value="0"
                            SmallChange="0.05"
                            StepFrequency="0.001"
                            MinWidth="220"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            ValueChanged="PlaybackProgressSlider_ValueChanged"/>
                    <Button x:Name="PlaybackOverlayPlayPauseButton"
                            Grid.Column="2"
                            Width="32"
                            Height="32"
                            Margin="0"
                            Padding="0"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Background="Transparent"
                            CornerRadius="16"
                            Click="PlaybackOverlayPlayPauseButton_Click">
                        <FontIcon x:Name="PlaybackOverlayPlayPauseIcon"
                                  Glyph="&#xF5B0;"
                                  FontFamily="Segoe Fluent Icons"
                                  FontSize="16"/>
                    </Button>
                    <Button x:Name="PlaybackOverlayStopButton"
                            Grid.Column="3"
                            Style="{StaticResource ToolbarIconOnlyButtonStyle}"
                            Visibility="Collapsed"
                            Width="32"
                            Height="32"
                            Margin="0"
                            Padding="0"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Background="Transparent"
                            CornerRadius="16"
                            Click="PlaybackOverlayStopButton_Click">
                        <FontIcon Glyph="&#xEE95;"
                                  FontFamily="Segoe Fluent Icons"
                                  FontSize="16"/>
                    </Button>
                    <Button x:Name="PlaybackOverlayVolumeButton"
                            Grid.Column="4"
                            Width="32"
                            Height="32"
                            Margin="0"
                            Padding="0"
                            Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                            VerticalAlignment="Center"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Background="Transparent"
                            CornerRadius="16">
                        <Button.Flyout>
                            <Flyout Placement="TopEdgeAlignedRight">
                                <Grid MinWidth="232"
                                      ColumnSpacing="8"
                                      Padding="0" Margin="-8,-6,-10,-8"
                                      VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0"
                                              Glyph="&#xE767;"
                                              FontFamily="Segoe Fluent Icons"
                                              FontSize="15"
                                              VerticalAlignment="Center"/>
                                    <Slider x:Name="PlaybackVolumeSlider"
                                            Grid.Column="1"
                                            Minimum="0"
                                            Maximum="100"
                                            Value="80"
                                            SmallChange="2"
                                            StepFrequency="1"
                                            Height="32"
                                            MinWidth="156"
                                            VerticalAlignment="Center"
                                            ValueChanged="PlaybackVolumeSlider_ValueChanged"/>
                                    <TextBlock x:Name="PlaybackVolumeValueText"
                                               Grid.Column="2"
                                               MinWidth="24"
                                               VerticalAlignment="Center"
                                               Text="80"
                                               FontSize="14"/>
                                </Grid>
                            </Flyout>
                        </Button.Flyout>
                        <FontIcon Glyph="&#xE767;"
                                  FontFamily="Segoe Fluent Icons"
                                  FontSize="15"/>
                    </Button>
                </Grid>
            </Border>

            <Border x:Name="PrintBusyOverlay"
                    Visibility="Collapsed"
                    Background="Transparent"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    IsHitTestVisible="True">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MinWidth="340"
                        MaxWidth="480"
                        Padding="18,16"
                        Background="{ThemeResource PlaybackOverlayAcrylicBrush}"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        CornerRadius="16"
                        Translation="0,0,16"
                        Shadow="{StaticResource ToolbarShadow}">
                    <StackPanel Spacing="0">
                        <ProgressBar x:Name="PrintBusyProgressBar"
                                     Height="6"
                                     IsIndeterminate="True"
                                     ShowError="False"
                                     ShowPaused="False"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>

        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Delete" Invoked="DeleteKey_Invoked"/>
            <KeyboardAccelerator Key="Back" Invoked="DeleteKey_Invoked"/>
            <KeyboardAccelerator Key="Z" Modifiers="Control" Invoked="UndoKey_Invoked"/>
            <KeyboardAccelerator Key="Y" Modifiers="Control" Invoked="RedoKey_Invoked"/>
            <KeyboardAccelerator Key="C" Modifiers="Control" Invoked="CopyKey_Invoked"/>
            <KeyboardAccelerator Key="X" Modifiers="Control" Invoked="CutKey_Invoked"/>
            <KeyboardAccelerator Key="V" Modifiers="Control" Invoked="PasteKey_Invoked"/>
            <KeyboardAccelerator Key="A" Invoked="AKey_Invoked"/>
            <KeyboardAccelerator Key="D" Invoked="DKey_Invoked"/>
        </Grid.KeyboardAccelerators>
    </Grid>
</Page>
















